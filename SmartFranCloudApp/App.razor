<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="typeof(App).Assembly">
	<Found Context="routeData">
		<RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
		<FocusOnNavigate RouteData="routeData" Selector="h1" />
	</Found>

    <NotFound>
		<LayoutView Layout="typeof(SmartFranCloudApp.Layout.EmptyLayout)">
			<PageTitle>404 · SmartFran Cloud</PageTitle>
			<SmartFranCloudApp.Pages.NotFound />
		</LayoutView>
	</NotFound>
</Router>

@code {
	private MudTheme _theme = SmartFranTheme.Create();
}
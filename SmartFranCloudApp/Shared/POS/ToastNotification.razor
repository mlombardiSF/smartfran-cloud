@namespace SmartFranCloudApp.Shared.POS

<div class="toast @(_animating && IsVisible ? "toast--show" : "")"
     style="--ta:@AccentGradient;--tc:@PulseColor;--td:@(DurationMs)ms">

	@* Acento izquierdo *@
	<div class="toast__accent"></div>

	@* Contenido *@
	<div class="toast__body">
		<div class="toast__content">

			@* Ícono con pulse ring *@
			<div class="toast__icon-wrap">
				<div class="toast__icon">
					<span
						class="material-symbols-outlined"
						style="color:#fff; font-size:1.1em; font-variation-settings:'FILL' 1;"
					>
						@Icon
					</span>
				</div>
				<span class="toast__pulse-ring"></span>
			</div>

			@* Texto *@
			<div class="toast__text">
				<p class="toast__title">@Title</p>
				<p class="toast__subtitle">@Subtitle</p>
			</div>

			@* Cerrar *@
			<button class="toast__close" @onclick="OnClose">
				<span class="material-symbols-outlined" style="font-size:0.9rem;">close</span>
			</button>
		</div>

		@* Barra de progreso *@
		<div class="toast__progress-track">
			<div class="toast__progress-bar @(_animating && IsVisible ? "toast__progress-bar--running" : "")"></div>
		</div>
	</div>

</div>

@code {
	[Parameter] public bool          IsVisible      { get; set; } = true;
	[Parameter] public string        Icon           { get; set; } = "point_of_sale";
	[Parameter] public string        Title          { get; set; } = string.Empty;
	[Parameter] public string        Subtitle       { get; set; } = string.Empty;
	[Parameter] public string        AccentGradient { get; set; } = "linear-gradient(135deg,#6e59ee,#9080f5)";
	[Parameter] public string        PulseColor     { get; set; } = "#9080f5";
	[Parameter] public int           DurationMs     { get; set; } = 4500;
	[Parameter] public EventCallback OnClose        { get; set; }

	private bool _animating = false;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await Task.Yield();
			_animating = true;
			StateHasChanged();
		}
	}
}

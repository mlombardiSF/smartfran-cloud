@namespace SmartFranCloudApp.Shared.Nav

<div class="bottombar">
	<div class="bottombar__inner">

		@* Izquierda: versión + sync *@
		<div class="bottombar__left">
			<div class="bottombar__status">
				<span class="bottombar__dot"></span>
				<span class="bottombar__version-text">
					Versión actual: <strong class="bottombar__version-num">2.18.00</strong>
				</span>
			</div>
			<div class="bottombar__divider"></div>
			<span class="bottombar__sync">
				Cloud Sync: <strong class="bottombar__sync-time">2 minutos atrás</strong>
			</span>
		</div>

		@* Derecha: botones *@
		<div class="bottombar__right">
			<button class="bottombar__btn bottombar__btn--outline">
				Ver Informes
			</button>
			<button class="bottombar__btn bottombar__btn--primary">
				Gestionar Franquicias
			</button>
		</div>

	</div>
</div>

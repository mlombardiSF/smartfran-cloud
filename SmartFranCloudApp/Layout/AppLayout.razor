@* AppLayout.razor — Layout para pantallas internas del sistema
  Fondo claro #fdf7ff, con TopNavBar y BottomBar fijos.
*@

@inherits LayoutComponentBase
@using SmartFranCloudApp.Themes
@using SmartFranCloudApp.Shared.Nav
@using SmartFranCloudApp.Shared.POS
@inject UserService UserSvc

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-layout">
  <TopNavBar UserName="@UserSvc.CurrentUser.FullName" AvatarUrl="@UserSvc.CurrentUser.AvatarPath" />

  <main class="app-layout__main">
    @Body
  </main>

  <BottomBar />
  <ToastStack />
</div>

@code {
  private MudTheme _theme = SmartFranTheme.Create();
}

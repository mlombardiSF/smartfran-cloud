@page "/forgot-password"

@layout EmptyLayout

@using SmartFranCloudApp.Shared
@using SmartFranCloudApp.Shared.Decorations

<PageTitle>SFC - Recuperar Contraseña</PageTitle>

<PageBackground>
  <div class="rp-root">
    <main class="rp-main">
			@* ── Brand Header (idéntico al login) ──────────────────────── *@
			<header class="rp-brand">
				<div class="rp-brand__icon">
					<span
						class="material-symbols-outlined"
						style="font-variation-settings:'FILL' 1; color:#c5bbff;"
					>
						cloud
					</span>
				</div>
				<div class="rp-brand__logo">
					<img 
						src="assets/svgs/Smartfran-Cloud-logo.svg"
						alt="SmartFran Cloud"
						onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
					/>
					<span class="rp-brand__logo-fallback">SmartFran Cloud</span>
				</div>
				<p class="rp-brand__subtitle">
					Velocidad y Precisión en tu Punto de Venta
				</p>
			</header>

      @* Glass Card *@
			<GlassCard 
				Variant="GlassCard.GlassVariant.Subtle"
				Radius="GlassCard.GlassRadius.Lg"
				Style="width:100%; padding: 2.5em 2.2em;"
			>
				@if (!_enviado)	{
					@* Estado: formulario *@
					<div class="rp-card-header">
						<h2 class="rp-card-title">Solicitud de Reseteo</h2>
						<p class="rp-card-desc">
							Introducí tu correo electrónico institucional para recibir las instrucciones de recuperación.
						</p>
					</div>

					<SfInput 
						Label="Correo electrónico"
						Icon="alternate_email"
						Type="email"
						Placeholder="usuario@smartfran.com"
						AutoComplete="email"
						Value="@_email"
						ValueChanged="@(v => _email = v)"
						HasError="@_hasError"
						ErrorText="@_errorText"
					/>

					<SfButton
						OnClick="HandleEnviar"
						IsLoading="@_isLoading"
						TrailingIcon="arrow_forward"
					>
						Enviar enlace de recuperación
					</SfButton>

					<footer class="rp-card-footer">
						<a class="rp-back-link" href="login">
							<span class="material-symbols-outlined rp-back-icon">arrow_back</span>
							<span>Volver al inicio de sesión</span>
						</a>
						</footer>
				}else	{
					@* Estado: éxito *@
					<div class="rp-success">
						<div class="rp-success__icon-wrap">
							<span
								class="material-symbols-outlined rp-success__icon"
								style="font-variation-settings:'FILL' 1;"
							>
								mark_email_read
							</span>
						</div>
						<h2 class="rp-card-title">¡Correo enviado!</h2>
						<p class="rp-card-desc">
							Revisá tu bandeja de entrada en
							<strong class="rp-email-highlight">@_email</strong>.
							El enlace expira en 30 minutos.
						</p>
						<p class="rp-success__hint">
								¿No lo encontrás? Revisá la carpeta de spam.
						</p>
					</div>

					<SfButton
						OnClick="@(() => { _enviado = false; _email = string.Empty; })"
						Variant="SfButton.SfButtonVariant.Secondary"
						TrailingIcon=""
					>
						Intentar con otro correo
					</SfButton>

					<footer class="rp-card-footer">
						<a class="rp-back-link" href="login">
							<span class="material-symbols-outlined rp-back-icon">arrow_back</span>
							<span>Volver al inicio de sesión</span>
						</a>
					</footer>
				}

			</GlassCard>

			@* Feature pills *@
			<div class="rp-features">
				<div class="rp-feature">
					<span class="material-symbols-outlined">bolt</span>
					<span>Sincronización Instantánea</span>
				</div>
				<div class="rp-feature">
					<span class="material-symbols-outlined">shield</span>
					<span>Seguridad de Grado Bancario</span>
				</div>
				<div class="rp-feature">
					<span class="material-symbols-outlined">query_stats</span>
					<span>Analítica en Tiempo Real</span>
				</div>
			</div>
    </main>
  </div>
</PageBackground>

@code {
    private string _email     = string.Empty;
    private bool   _isLoading = false;
    private bool   _enviado   = false;
    private bool   _hasError  = false;
    private string _errorText = string.Empty;

    private async Task HandleEnviar()
    {
        _hasError  = false;
        _errorText = string.Empty;

        if (string.IsNullOrWhiteSpace(_email))
        {
            _hasError  = true;
            _errorText = "El correo es obligatorio.";
            return;
        }

        if (!_email.Contains('@') || !_email.Contains('.'))
        {
            _hasError  = true;
            _errorText = "Ingresá un correo válido.";
            return;
        }

        _isLoading = true;
        StateHasChanged();

        await Task.Delay(1400); // reemplazar con llamada real a API

        _isLoading = false;
        _enviado   = true;
    }
}

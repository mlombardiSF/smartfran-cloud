		new() { Id="p1",  Name="Mini Gigante",                      Category="Helados",  Price=1400,  ImageUrl="assets/images/catalog/mini-gigante.png",               IsFavorite=true,  Tags=["cucurucho","cono","chico","pequeño","grido"] },

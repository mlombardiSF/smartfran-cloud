	private List<Product> _filteredProducts => _categoryActive switch
	{
		"Favoritos" => _allProducts.Where(p => p.IsFavorite).ToList(),
		"Promos"    => _allProducts.Take(4).ToList(), // placeholder
		_           => _allProducts.Where(p => p.Category == _categoryActive).ToList(),
	};

	// ── Acciones ───────────────────────────────────────────────────────────
	private void ToggleSidebar()  => _sidebarOpen = !_sidebarOpen;
	private void CloseSidebar()   => _sidebarOpen = false;
	private void ToggleSoundConfig() => _soundConfigOpen = !_soundConfigOpen;
	private void SelectCategory(string cat) => _categoryActive = cat;

	private void OpenSocioPanel()  => _socioPanelOpen = true;
  private void CloseSocioPanel()  => _socioPanelOpen = false;

	private void AddProduct(Product p) {
		Cart.AddProduct(p);
		StateHasChanged();
	}

	private void OpenKanban()  => _kanbanOpen = true;
	private void CloseKanban() => _kanbanOpen = false;

	private void OpenModalPayment()  => _paymentModalOpen = true;
	private void ClosePaymentModal() => _paymentModalOpen = false;
}

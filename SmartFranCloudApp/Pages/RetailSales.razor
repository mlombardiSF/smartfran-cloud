@page "/retail-sales"

@layout PosLayout

@using SmartFranCloudApp.Models
@using SmartFranCloudApp.Services
@using SmartFranCloudApp.Shared.Nav
@using SmartFranCloudApp.Shared.POS.Venta

@inject CartService Cart
@inject UserService UserSvc

<PageTitle>SFC | POS</PageTitle>

<div class="vm-root">

	<PaymentModal
		IsOpen="@_paymentModalOpen"
		OnClose="ClosePaymentModal"
		OnPaymentConfirmed="ClosePaymentModal"
	/>

	<KanbanModal
		IsOpen="@_kanbanOpen"
		OnClose="CloseKanban"
	/>

	@* ── TopNav del POS ──────────────────────────────────────────────────── *@
	<PosNavBar
		UserName="@UserSvc.CurrentUser.FullName"
		AvatarUrl="@UserSvc.CurrentUser.AvatarPath"
		Terminal="Mostrador 001"
		Shift="0345"
		Products="@_allProducts"
		OnMenuToggle="ToggleSidebar"
		OnSoundConfig="ToggleSoundConfig"
		OnProductSelect="AddProduct"
	/>

	@* ── Sidebar de navegación ───────────────────────────────────────────── *@
	<SideNavBar IsOpen="@_sidebarOpen" OnClose="CloseSidebar" />

	@* ── Workspace principal ─────────────────────────────────────────────── *@
	<div class="vm-workspace">

		@* Panel socio slide — desde la izquierda, debajo del nav *@
        <SocioPanelSlide
					IsOpen="@_socioPanelOpen"
					OnClose="CloseSocioPanel" />

		@* ── Zona izquierda: categorías + grilla ─────────────────────────── *@
		<div class="vm-catalog">

			@* Barra superior: categorías + botón pedidos *@
			<div class="vm-catalog__topbar">
				<CategoryBar 
					CategoriesMain="@_categoriesMain"
					CategoriesExtra="@_categoriesExtra"
					CategoryActive="@_categoryActive"
					OnCategorySelect="SelectCategory"
				/>

				<div class="vm-catalog__pedidos">
						<OrdersButton
							PendingOrders="@_pendingOrders"
							OnClick="OpenKanban"
							@ref="_ordersBtn"
						/>
				</div>
			</div>

			@* Grilla de productos *@
			<div class="vm-catalog__grid-wrap">
				<div class="vm-catalog__grid">
					@foreach (var p in _filteredProducts) {
						<ProductCard 
							Product="p" 
							OnAdd="AddProduct"
						/>
					}

					@if (!_filteredProducts.Any()) {
						<div class="vm-catalog__empty">
							<span class="material-symbols-outlined vm-catalog__empty-icon">
								search_off
							</span>
							<p>Sin productos en esta categoría</p>
						</div>
					}
				</div>
			</div>

		</div>

		@* ── Panel derecho: carrito ───────────────────────────────────────── *@
		<CartPanel
			OnConfirmPayment="OpenModalPayment"
			OnOpenSocioPanel="OpenSocioPanel"
			OnSocioCleared="CloseSocioPanel" />

	</div>

	@* ── Panel derecho: carrito ───────────────────────────────────────── *@
	<div class="vm-scan">
		<span class="vm-note">Atención: Demo interactiva</span>
	</div>

</div>

@code {

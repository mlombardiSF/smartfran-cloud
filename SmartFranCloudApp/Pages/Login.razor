@page "/login"
@page "/"

@layout EmptyLayout

@using SmartFranCloudApp.Shared
@using SmartFranCloudApp.Shared.Decorations

<PageTitle>SFC - Iniciar Sesión</PageTitle>
<PageBackground>

	<div class="lg-root">
		<main class="lg-main">

			@* Brand Header *@
			<header class="lg-brand">
				<div class="lg-brand__icon">
					<span
						class="material-symbols-outlined"
						style="font-variation-settings:'FILL' 1; font-size:3rem; color:#c5bbff;"
					>
						cloud
					</span>
				</div>
				<div class="lg-brand__logo">
					<img
						src="assets/svgs/Smartfran-Cloud-logo.svg"
						alt="SmartFran Cloud"
						style="height:5em;"
						onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
					/>
					<span class="lg-brand__logo-fallback">SmartFran Cloud</span>
				</div>
				<p class="lg-brand__subtitle">
					Velocidad y Precisión en tu Punto de Venta
				</p>
			</header>

			@* Login Card *@
			<GlassCard
				Variant="GlassCard.GlassVariant.Subtle"
				Radius="GlassCard.GlassRadius.Lg"
				Style="padding: 2.5em 2.2em; width:100%;">

				<SfInput
					Label="Correo electrónico"
					Icon="alternate_email"
					Type="email"
					Placeholder="usuario@empresa.com"
					AutoComplete="email"
					Value="@_email"
					ValueChanged="@(v => _email = v)"
					HasError="@_fieldErrors.ContainsKey("email")"
					ErrorText="@(_fieldErrors.GetValueOrDefault("email", ""))" />

				<SfInput
					Label="Contraseña"
					Icon="lock"
					ShowToggle="true"
					Placeholder="••••••••••••"
					AutoComplete="current-password"
					Value="@_password"
					ValueChanged="@(v => _password = v)"
					HasError="@_fieldErrors.ContainsKey("password")"
					ErrorText="@(_fieldErrors.GetValueOrDefault("password", ""))" />

				<div class="lg-remember-row">
					<label class="lg-checkbox-label">
						<input class="lg-checkbox" type="checkbox" @bind="_rememberMe" />
						<span class="lg-remember-text">Recordarme</span>
					</label>
					<a class="lg-forgot-link" href="/forgot-password">
						¿Olvidaste tu contraseña?
					</a>
				</div>

				@if (!string.IsNullOrEmpty(_globalError)){
					<div class="lg-error-banner">
						<span class="material-symbols-outlined" style="font-size:18px;">error</span>
						@_globalError
					</div>
				}

				<SfButton
					OnClick="HandleLogin"
					IsLoading="@_isLoading"
					TrailingIcon="arrow_forward"
				>
					Iniciar sesión
				</SfButton>

				<footer class="lg-card-footer">
					<p class="lg-footer-text">Sistema de Gestión Empresarial Cerrado</p>
					<a class="lg-support-link" href="#">
						<span class="material-symbols-outlined" style="font-size:1rem;">support_agent</span>
						<span>Contactar con Soporte</span>
					</a>
				</footer>

			</GlassCard>

			@* Feature pills *@
			<div class="lg-features">
				<div class="lg-feature">
					<span class="material-symbols-outlined">bolt</span>
					<span>Sincronización Instantánea</span>
				</div>
				<div class="lg-feature">
					<span class="material-symbols-outlined">shield</span>
					<span>Seguridad de Grado Bancario</span>
				</div>
				<div class="lg-feature">
					<span class="material-symbols-outlined">query_stats</span>
					<span>Analítica en Tiempo Real</span>
				</div>
			</div>

		</main>
	</div>

</PageBackground>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private string _email       = string.Empty;
    private string _password    = string.Empty;
    private bool   _rememberMe  = false;
    private bool   _isLoading   = false;
    private string _globalError = string.Empty;
    private Dictionary<string, string> _fieldErrors = new();
		public record UserCredential(string Email, string Password);

		private readonly List<UserCredential> _validUsers = new()
    {
        new UserCredential("admin@smartfran.com", "1234"),
        new UserCredential("soporte@smartfran.com", "1234"),
        new UserCredential("matiasl@smartfran.com", "1234"),
    };

    private async Task HandleLogin(){
			_globalError = string.Empty;
			_fieldErrors = new();

			if (string.IsNullOrWhiteSpace(_email))
				_fieldErrors["email"] = "El correo es obligatorio.";
			if (string.IsNullOrWhiteSpace(_password))
				_fieldErrors["password"] = "La contraseña es obligatoria.";

			if (_fieldErrors.Count > 0) return;

			_isLoading = true;
			StateHasChanged();

			await Task.Delay(1200);

			if (_validUsers.Any(u => u.Email.Equals(_email, StringComparison.OrdinalIgnoreCase) && u.Password == _password)) {
				_globalError = "✓ Login exitoso — redirigiendo...";
				/* redirect */
				NavigationManager.NavigateTo("/selection-franchise", replace: true, forceLoad: true);
			} else {
				_globalError = "Credenciales incorrectas. Verificá tu correo y contraseña.";
			}

			_isLoading = false;
    }
}

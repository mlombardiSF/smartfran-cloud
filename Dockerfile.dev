# Dockerfile.dev – Solo para desarrollo con hot reload
FROM mcr.microsoft.com/dotnet/sdk:8.0
WORKDIR /app

EXPOSE 5000
EXPOSE 5001

# Entrypoint: parchea base href en el source montado al iniciar y lo restaura al salir
COPY scripts/docker-entrypoint-dev.sh /app/entrypoint-dev.sh
RUN chmod +x /app/entrypoint-dev.sh

CMD ["/app/entrypoint-dev.sh"]

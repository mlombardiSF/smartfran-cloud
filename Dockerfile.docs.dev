# Dockerfile.docs.dev – Desarrollo con hot reload para SmartFran.Docs
FROM mcr.microsoft.com/dotnet/sdk:8.0
WORKDIR /app

# Exponer puerto de desarrollo
EXPOSE 5001

# dotnet watch necesita ver tanto SmartFran.Docs como SmartFran.Components
# (montados como volúmenes en docker-compose)
CMD ["dotnet", "watch", "run", "--project", "SmartFran.Docs/SmartFran.Docs.csproj", \
     "--urls", "http://0.0.0.0:5001"]
